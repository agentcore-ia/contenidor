SUPABASE_URL=https://wdowrhbkzydwdcsxcxzg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5.4-mini
CONTENT_TIME_ZONE=America/Argentina/Buenos_Aires
PORT=3000

# Generacion de imagenes con IA (GPT Image 2)
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1280
OPENAI_IMAGE_QUALITY=high

# Automatizacion diaria (scheduler interno)
AUTOMATION_ENABLED=true
AUTOMATION_TIME=08:00
AUTOMATION_QUEUE_TARGET=7
AUTOMATION_AUTO_RENDER=true
AUTOMATION_AUTO_PUBLISH=true
AUTOMATION_RUN_ON_START=false

# SaaS (auth + onboarding)
SUPABASE_ANON_KEY=your-anon-key
APIFY_TOKEN=

# Publicacion en Instagram (Instagram API con Instagram Login)
# INSTAGRAM_APP_ID: el "ID de la app de Instagram" (Panel de Meta > API de
#   Instagram > Configuracion del inicio de sesion con Instagram). Puede diferir
#   del ID de la app de Meta.
# INSTAGRAM_REDIRECT_URI: debe coincidir EXACTO con el registrado en Meta.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=https://agentcore-contenidor.8zp1cp.easypanel.host/oauth/instagram/callback

# Aprobaciones por WhatsApp (WhatsApp Cloud API de Meta)
# WHATSAPP_PHONE_NUMBER_ID: id del numero emisor (WhatsApp > Configuracion de la API)
# WHATSAPP_TEMPLATE_NAME: plantilla aprobada con header de imagen + 2 botones de
#   respuesta rapida (Aprobar / Rechazar).
# WHATSAPP_VERIFY_TOKEN: cadena secreta para el handshake del webhook (la eliges vos).
# WHATSAPP_APP_SECRET: secret de la app de Meta para validar la firma del webhook.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=es
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Generacion de video. VIDEO_PROVIDER elige el proveedor: 'gemini' (Google
# Omni/Veo, pago por uso, recomendado) o 'higgsfield'. Sin la key del proveedor
# elegido, la funcion queda desactivada (no rompe nada).
VIDEO_PROVIDER=gemini

# Gemini (Google AI Studio): Omni Flash / Veo. Pago por uso. El usuario elige el
# motor (Omni o Veo 3) por video desde la UI; estos son los modelos de cada uno.
GEMINI_API_KEY=
GEMINI_VIDEO_MODEL=gemini-omni-flash-preview
GEMINI_OMNI_MODEL=gemini-omni-flash-preview
GEMINI_VEO_MODEL=veo-3.1-generate-preview
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_ASPECT_RATIO=9:16

# Higgsfield Cloud (alternativa). Auth = HTTP Basic base64(id:secret).
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_SECRET=
HIGGSFIELD_BASE_URL=https://api.higgsfield.ai/v1
HIGGSFIELD_VIDEO_MODEL=default-video-model
HIGGSFIELD_UGC_TASK=text-to-video
HIGGSFIELD_DURATION=5
